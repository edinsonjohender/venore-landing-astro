---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/sections/Navbar';
import { Footer } from '../../components/sections/Footer';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "VENORE"
  },
  "publisher": {
    "@type": "Organization",
    "name": "VENORE",
    "url": "https://venore.app"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://venore.app/blog/${post.slug}`
  }
};
---

<Layout title={`${post.data.title} | VENORE Blog`} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="min-h-screen flex flex-col">
  <Navbar client:load />

  <main class="pt-14 flex-1">
    <article class="container mx-auto px-6 py-16 max-w-3xl">
      <a href="/blog" class="text-sm text-foreground-muted hover:text-foreground transition-colors mb-8 inline-block">
        &larr; Back to blog
      </a>

      <header class="mb-10 text-center">
        <div class="flex items-center justify-center gap-2 text-sm text-foreground-muted mb-4">
          <span class="text-status-stable">{post.data.category}</span>
          <span>·</span>
          <time>
            {post.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>
        <p class="text-lg text-foreground-muted">{post.data.description}</p>
      </header>

      <div class="mb-10 rounded-lg overflow-hidden border border-border aspect-video bg-background-tertiary">
        {post.data.image ? (
          <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
        ) : (
          <div class="w-full h-full flex items-center justify-center">
            <div class="w-20 h-20 rounded-xl bg-status-stable/20 flex items-center justify-center">
              <svg class="w-10 h-10 text-status-stable" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
          </div>
        )}
      </div>

      <div class="blog-content">
        <Content />
      </div>
    </article>
  </main>

  <Footer />
  </div>
</Layout>

<style>
  .blog-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }

  .blog-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-foreground);
  }

  .blog-content :global(p) {
    margin-bottom: 1rem;
    line-height: 1.75;
    color: var(--color-foreground-muted);
  }

  .blog-content :global(a) {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-content :global(a:hover) {
    opacity: 0.8;
  }

  .blog-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background: var(--color-background-tertiary);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }

  .blog-content :global(pre) {
    background: var(--color-background-secondary);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .blog-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .blog-content :global(li) {
    margin-bottom: 0.5rem;
    color: var(--color-foreground-muted);
  }

  .blog-content :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-foreground-muted);
  }

  .blog-content :global(hr) {
    border-color: var(--color-border);
    margin: 2rem 0;
  }

  .blog-content :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
</style>
